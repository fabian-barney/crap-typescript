{
  "name": "@barney-media/crap-typescript",
  "version": "0.2.3",
  "description": "CLI for CRAP metric analysis in TypeScript projects.",
  "license": "Apache-2.0",
  "author": "Fabian Barney (https://github.com/fabian-barney)",
  "keywords": [
    "crap",
    "crap-score",
